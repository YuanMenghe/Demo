{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zhihui-mdt.local/schemas/patient-ui.schema.json",
  "title": "MDT Patient UI Projection",
  "description": "Patient payload consumed by the current frontend render pipeline (mockPatients-compatible).",
  "type": "object",
  "required": [
    "id",
    "name",
    "gender",
    "age",
    "disease",
    "treatment",
    "group",
    "lastUpdate",
    "complications",
    "timeline",
    "indicators",
    "basicInfo"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "gender": {
      "type": "string",
      "minLength": 1,
      "description": "Display value used in UI, typically 男 or 女."
    },
    "age": {
      "type": "integer",
      "minimum": 0,
      "maximum": 130
    },
    "disease": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string"
    },
    "complications": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "treatment": {
      "type": "string",
      "minLength": 1
    },
    "group": {
      "type": "string",
      "description": "Group id; empty string means ungrouped in current UI."
    },
    "lastUpdate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}( \\d{2}:\\d{2})?$",
      "description": "Format used in current cards: YYYY-MM-DD HH:mm"
    },
    "timeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/TimelineEventUI"
      }
    },
    "indicators": {
      "type": "object",
      "description": "Key is indicator name (e.g., AFP/CEA), value is date-value series.",
      "additionalProperties": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/IndicatorSeriesPoint"
        }
      }
    },
    "basicInfo": {
      "$ref": "#/$defs/BasicInfo"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "TimelineEventUI": {
      "type": "object",
      "required": [
        "date",
        "title",
        "hospital",
        "type"
      ],
      "properties": {
        "date": {
          "type": "string",
          "format": "date"
        },
        "title": {
          "type": "string"
        },
        "hospital": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "admission",
            "imaging",
            "diagnosis",
            "treatment",
            "surgery",
            "followup",
            "mdt",
            "relapse",
            "progression",
            "evaluation",
            "examination",
            "default",
            "other"
          ]
        },
        "desc": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "IndicatorSeriesPoint": {
      "type": "object",
      "required": [
        "date",
        "value"
      ],
      "properties": {
        "date": {
          "type": "string",
          "format": "date"
        },
        "value": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "BasicInfo": {
      "type": "object",
      "required": [
        "chiefComplaint",
        "presentHistory",
        "pastHistory",
        "familyHistory",
        "personalHistory"
      ],
      "properties": {
        "chiefComplaint": {
          "type": "string"
        },
        "presentHistory": {
          "type": "string"
        },
        "pastHistory": {
          "type": "string"
        },
        "familyHistory": {
          "type": "string"
        },
        "personalHistory": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
