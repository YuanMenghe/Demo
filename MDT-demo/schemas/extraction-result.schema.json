{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zhihui-mdt.local/schemas/extraction-result.schema.json",
  "title": "Patient Extraction Result",
  "description": "Envelope produced by the extraction pipeline. Contains only fields required to populate the UI data structure.",
  "type": "object",
  "required": [
    "schemaVersion",
    "extractionId",
    "extractedAt",
    "sourceDocuments",
    "patientRecord",
    "quality"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "extractionId": {
      "type": "string"
    },
    "extractedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceDocuments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/SourceDocument"
      }
    },
    "patientRecord": {
      "$ref": "./patient-canonical.schema.json"
    },
    "uiProjection": {
      "$ref": "./patient-ui.schema.json"
    },
    "quality": {
      "type": "object",
      "required": [
        "overallConfidence",
        "completenessScore",
        "validationStatus"
      ],
      "properties": {
        "overallConfidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "completenessScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "validationStatus": {
          "type": "string",
          "enum": [
            "pass",
            "warn",
            "fail"
          ]
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "SourceDocument": {
      "type": "object",
      "required": [
        "documentId",
        "fileName"
      ],
      "properties": {
        "documentId": {
          "type": "string"
        },
        "fileName": {
          "type": "string"
        },
        "mimeType": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}